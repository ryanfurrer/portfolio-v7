---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import BackToTop from "@/components/BackToTop.tsx";
import Footer from "@/components/Footer.astro";
import Head from "@/components/Head.astro";
import Navbar from "@/components/Navbar.astro";
import ScrollFade from "@/components/ScrollFade.astro";
import { cn } from "@/lib/utils";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noNavbar?: boolean;
  noFooter?: boolean;
  maxWidth?: "sm" | "lg";
}

const {
  title = "Ryan Furrer — Frontend Engineer and Designer",
  description = "Frontend engineer focused on crafting accessible, fast, and delightful user experiences.",
  ogImage,
  noNavbar = false,
  noFooter = false,
  maxWidth = "lg",
} = Astro.props;

// Back-to-top lives only on long-form content sections.
const contentPrefixes = ["/writing", "/work", "/appearances", "/now"];
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isContentPage = contentPrefixes.some(
  (p) => path === p || path.startsWith(`${p}/`),
);
---

<html lang="en">
  <Head title={title} description={description} ogImage={ogImage} />
  <body class="bg-background text-foreground-muted antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:start-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-foreground focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-background"
    >
      Skip to content
    </a>
    <!-- Sticky header: transparent at the top, then a translucent blurred bar
         with a hairline border once scrolled (data-scrolled, set by
         sticky-header.ts). will-change:transform pins it to its own compositing
         layer so iOS Safari repaints it (and its backdrop-filter) smoothly during
         momentum scroll — otherwise it only redraws on scroll-up. -->
    {
      !noNavbar && (
        <header
          data-site-header
          class="sticky top-0 z-40 transform-[translateZ(0)] border-b border-transparent transition-[background-color,border-color,translate] duration-300 ease-out will-change-transform data-hidden:-translate-y-full data-scrolled:border-border data-scrolled:bg-background/70 data-scrolled:backdrop-blur-xl"
        >
          <div class="mx-auto max-w-280 px-4 lg:grid lg:grid-cols-[12rem_1fr_12rem] lg:gap-x-8">
            <div
              class={cn(
                "py-4 lg:col-start-2",
                maxWidth === "sm"
                  ? "mx-auto max-w-sm lg:mx-0 lg:max-w-none"
                  : "mx-auto max-w-2xl lg:mx-0 lg:max-w-none",
              )}
            >
              <Navbar />
            </div>
          </div>
        </header>
      )
    }

    <div
      class="mx-auto max-w-280 px-4 py-8 lg:grid lg:grid-cols-[12rem_1fr_12rem] lg:gap-x-8"
    >
      <!-- Left gutter -->
      <aside class="hidden lg:col-start-1 lg:block">
        <slot name="left" />
      </aside>

      <!-- Center: same width on every page -->
      <div
        id="main-content"
        tabindex="-1"
        class={cn(
          "space-y-16 min-w-0 scroll-mt-24 focus:outline-none lg:col-start-2",
          maxWidth === "sm"
            ? "max-w-sm mx-auto lg:max-w-none lg:mx-0"
            : "max-w-2xl mx-auto lg:max-w-none lg:mx-0",
        )}
      >
        <slot />
        {isContentPage && <div id="content-end" aria-hidden="true" class="mt-0!"></div>}
        {!noFooter && <Footer />}
      </div>

      <!-- Right gutter -->
      <aside class="hidden lg:col-start-3 lg:block">
        <slot name="right" />
      </aside>
    </div>
    <ScrollFade />
    {isContentPage && <BackToTop client:load />}
    <Analytics />
    <SpeedInsights />
    <script>
      import "@/scripts/dir-hover";
      import "@/scripts/sticky-header";
      import "@/scripts/reveal";
    </script>
  </body>
</html>
