---
interface Props {
  href: string;
  label: string;
  class?: string;
}

const { href, label, class: className } = Astro.props;
---

<a
  href={href}
  data-back
  class:list={[
    "group/back not-prose inline-flex w-fit items-center gap-1 text-sm font-medium text-link no-underline transition-colors hover:text-link-hover focus-visible:text-link-hover active:text-link-hover",
    className,
  ]}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="size-4 shrink-0 transition-transform duration-150 ease-out group-hover/back:-translate-x-0.5"
    aria-hidden="true"
  >
    <path d="M15 18l-6-6 6-6"></path>
  </svg>
  <span data-back-label>{label}</span>
</a>
