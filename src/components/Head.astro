---
import { SITE_TITLE, SITE_DESCRIPTION } from "@/consts";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** schema.org structured data, rendered as a JSON-LD script. */
  jsonLd?: Record<string, unknown>;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  ogImage,
  jsonLd,
} = Astro.props;

const ogUrl = new URL(Astro.url.pathname, Astro.site).toString();
const defaultOgImage = new URL("/og-image.png", Astro.site).toString();
const ogImageUrl = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : new URL(ogImage, Astro.site).toString()
  : defaultOgImage;
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="theme-color" content="#ffffff" />
  {/* Resolve the saved theme choice (or fall back to the OS preference) and
      apply the .dark class to <html> before first paint — no flash of the
      wrong theme. Also syncs the browser-chrome color. ModeToggle keeps both in
      step at runtime. Mirrors the resolution in ModeToggle.tsx. */}
  <script is:inline>
    (() => {
      try {
        const stored = localStorage.getItem("theme");
        const dark =
          stored === "dark" ||
          ((stored === "system" || !stored) &&
            matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.classList.toggle("dark", dark);
        const meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute("content", dark ? "#1a1a1a" : "#ffffff");
      } catch {}
    })();
  </script>
  {/* Arm the entrance reveal before paint so [data-reveal] content starts
      hidden — but only when JS is on and motion is allowed. See
      scripts/reveal.ts. */}
  <script is:inline>
    (() => {
      try {
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        document.documentElement.classList.add("reveal-init");
      } catch {}
    })();
  </script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link
    rel="preload"
    href="/assets/fonts/Geist[wght].woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href="/assets/fonts/Geist-Italic[wght].woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href="/assets/fonts/BerkeleyMono-Regular.woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href="/assets/fonts/PermanentMarker-Regular.ttf"
    as="font"
    type="font/ttf"
    crossorigin
  />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="canonical" href={ogUrl} />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={ogUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImageUrl} />
  {jsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />}
</head>
