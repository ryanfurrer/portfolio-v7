---
import logo from "@/assets/logo.svg";
import { cn } from "@/lib/utils";

const navItems = [
  {
    label: "Writing",
    href: "/writing",
  },
  {
    label: "Work",
    href: "/work",
  },
  {
    label: "Appearances",
    href: "/appearances",
  },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(`${href}/`);
---

<nav class="mb-16 md:px-2">
  <div class="flex items-center justify-between">
    <a
      href="/"
      name="go to home page"
      class="rounded-sm transition-all hover:saturate-100 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-link md:saturate-70"
      ><img src={logo.src} alt="Ryan Furrer" class="size-8" /></a
    >
    <ul class="flex gap-4 text-sm" role="list">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              name={`go to ${item.label.toLowerCase()} page`}
              aria-current={isActive(item.href) ? "page" : undefined}
              class={cn(
                "text-color-hover font-medium focus:text-foreground aria-[current=page]:text-foreground",
                isActive(item.href)
                  ? "text-foreground"
                  : "text-foreground-muted",
              )}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
