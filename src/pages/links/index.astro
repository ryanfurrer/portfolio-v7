---
import BlueskyIcon from "@/assets/icons/bluesky.svg";
import GithubIcon from "@/assets/icons/github.svg";
import LinkedinIcon from "@/assets/icons/linkedin.svg";
import TwitchIcon from "@/assets/icons/twitch.svg";
import XIcon from "@/assets/icons/x.svg";
import YoutubeIcon from "@/assets/icons/youtube.svg";
import LinksCard from "@/components/ui/LinksCard.astro";
import Layout from "@/layouts/Layout.astro";
import { socialLinks } from "@/lib/social-links";
import { LINKS_LATEST_QUERY } from "@/sanity/lib/queries";
import { SECTION_META } from "@/lib/og/sections";
import type { LINKS_LATEST_QUERY_RESULT } from "@/sanity/sanity.types";
import { sanityClient } from "sanity:client";
import { formatFollowerCount } from "@/utils/links";

// Icon keys in the shared social-links data resolve to SVG components here,
// keeping the data file free of framework imports.
const socialIcons: Record<string, typeof GithubIcon> = {
  linkedin: LinkedinIcon,
  x: XIcon,
  bluesky: BlueskyIcon,
  twitch: TwitchIcon,
  github: GithubIcon,
  youtube: YoutubeIcon,
};

// These values mirror the public API's platform names. LinkedIn deliberately
// has no entry because its count remains a manually maintained fallback.
const livePlatformByIcon: Record<string, string | undefined> = {
  x: "Twitter",
  bluesky: "Bluesky",
  twitch: "Twitch",
  github: "GitHub",
  youtube: "YouTube",
};

// Card order reflects where visitors are most likely to follow, watch, or see
// Ryan's work. The footer retains the shared social-link order.
const socialCards = [...socialLinks].sort(
  (a, b) => a.linksPageOrder - b.linksPageOrder,
);

type LatestLinkItem = NonNullable<LINKS_LATEST_QUERY_RESULT["post"]>;

const {
  post: latestPost,
  project: latestProject,
  appearance: latestAppearance,
} = await sanityClient.fetch<LINKS_LATEST_QUERY_RESULT>(LINKS_LATEST_QUERY);

const latestContentItems = [
  { type: "writing", path: "writing", item: latestPost },
  { type: "work", path: "work", item: latestProject },
  { type: "appearance", path: "appearances", item: latestAppearance },
]
  .filter(
    (content): content is typeof content & { item: LatestLinkItem } =>
      content.item !== null,
  )
  // The card art is the same build-time OG image the shared page uses
  // (/og/<section>/<slug>.png), so these previews always match.
  .map((content) => ({
    ...content,
    ogImageUrl: content.item.slug?.current
      ? `/og/${content.path}/${content.item.slug.current}.png`
      : undefined,
  }));

const description = SECTION_META.links.description;
---

<Layout
  title="Links — Ryan Furrer"
  description={description}
  ogImage="/og/links.png"
>
  <div class="space-y-16">
    <header class="space-y-3">
      <h1 class="text-2xl text-balance text-foreground sm:text-3xl" data-reveal>
        Links
      </h1>
      <p class="lead max-w-[52ch]" data-reveal>
        {description}
      </p>
    </header>

    <main class="space-y-16">
      <section class="space-y-4">
        <h2 class="small-heading" data-reveal>Connect with me</h2>
        <div class="grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3">
          {
            socialCards.map((link) => {
              const IconComponent = socialIcons[link.icon ?? ""];
              const livePlatform = livePlatformByIcon[link.icon ?? ""];
              const followLabel =
                link.actionLabel === "Subscribe" ? "subscribers" : "followers";
              return (
                <LinksCard
                  href={link.href}
                  class="group squircle rounded-3xl p-4"
                >
                  <div class="flex h-full flex-col justify-between gap-6">
                    <div class="flex items-start justify-between gap-2">
                      <IconComponent
                        class:list={[
                          "squircle size-10 shrink-0 rounded-xl p-2.5",
                          link.iconFill,
                          link.iconBackground,
                        ]}
                      />
                      <span class="pointer-events-none inline-flex items-center gap-1 text-xs font-medium text-foreground-subtle transition-colors duration-200 ease-out can-hover:group-hover:text-foreground-muted">
                        {link.actionLabel}
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="size-3.5 transition-transform duration-200 ease-out can-hover:group-hover:translate-x-0.5 can-hover:group-hover:-translate-y-0.5"
                          aria-hidden="true"
                        >
                          <path d="M7 7h10v10" />
                          <path d="M7 17 17 7" />
                        </svg>
                      </span>
                    </div>
                    <div>
                      <h3 class="small-heading leading-none">{link.label}</h3>
                      {
                        link.followerCount !== undefined ? (
                          <>
                            <p class="mt-2.5 text-4xl leading-none font-bold text-foreground tabular-nums">
                              <span data-social={livePlatform}>
                                {formatFollowerCount(link.followerCount)}
                              </span>
                            </p>
                            <p class="mt-2 text-sm leading-none text-foreground-subtle">
                              {followLabel}
                            </p>
                          </>
                        ) : (
                          <p class="mt-2.5 text-base leading-none font-medium text-foreground-subtle">
                            {link.description}
                          </p>
                        )
                      }
                    </div>
                  </div>
                </LinksCard>
              );
            })
          }
        </div>
      </section>

      {
        latestContentItems.length > 0 && (
          <section class="space-y-4">
            <h2 class="small-heading" data-reveal>
              Latest from me
            </h2>
            <div class="space-y-4">
              {latestContentItems.map((content) => (
                <a
                  href={`/${content.path}/${content.item.slug?.current}`}
                  data-reveal
                  class="group squircle block overflow-hidden rounded-2xl no-underline ring-1 ring-black/10 transition duration-200 ease-out hover:shadow-sm active:scale-[0.99] motion-reduce:active:scale-100 dark:ring-white/10 dark:hover:shadow-none"
                >
                  {content.ogImageUrl ? (
                    <img
                      src={content.ogImageUrl}
                      alt={content.item.title ?? ""}
                      loading="lazy"
                      class="aspect-1200/630 w-full object-cover transition-transform duration-500 ease-out motion-reduce:transition-none motion-reduce:group-hover:scale-100 can-hover:group-hover:scale-[1.015]"
                    />
                  ) : (
                    <div class="flex aspect-1200/630 w-full flex-col justify-center gap-2 bg-surface p-6 sm:p-8">
                      <p class="small-heading">{content.type}</p>
                      <h3 class="text-xl font-bold text-balance text-foreground sm:text-2xl">
                        {content.item.title}
                      </h3>
                    </div>
                  )}
                  <span class="sr-only">
                    {content.type}: {content.item.title}
                  </span>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </main>
  </div>

  <script>
    const formatter = new Intl.NumberFormat("en-US", {
      notation: "compact",
      maximumFractionDigits: 1,
    });

    try {
      const response = await fetch(
        "https://giant-weasel-235.convex.site/api/socials",
      );

      if (response.ok) {
        const socials: { platform: string; follower_count: number }[] =
          await response.json();
        const byPlatform = new Map(
          socials.map((social) => [social.platform.toLowerCase(), social]),
        );

        for (const element of document.querySelectorAll<HTMLElement>(
          "[data-social]",
        )) {
          const social = byPlatform.get(
            element.dataset.social?.toLowerCase() ?? "",
          );
          if (social && typeof social.follower_count === "number") {
            element.textContent = formatter.format(social.follower_count);
          }
        }
      }
    } catch {
      // Keep the static fallback counts when the API is unavailable.
    }
  </script>
</Layout>
