---
import MobileNav from "@/components/MobileNav";
import ModeToggle from "@/components/ModeToggle";
import Presence from "@/components/Presence";
import { cn } from "@/lib/utils";

const navItems = [
  {
    label: "Writing",
    href: "/writing",
  },
  {
    label: "Work",
    href: "/work",
  },
  {
    label: "Appearances",
    href: "/appearances",
  },
  {
    label: "Now",
    href: "/now",
  },
  {
    label: "About",
    href: "/about",
  },
];

// Mobile menu leads with Home (the logo is the only desktop home affordance)
// and includes Links, which is intentionally kept out of the desktop nav.
const mobileNavItems = [
  { label: "Home", href: "/" },
  ...navItems,
  { label: "Links", href: "/links" },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/"
    ? pathname === "/"
    : pathname === href || pathname.startsWith(`${href}/`);
---

<nav class="md:px-2">
  <div class="flex items-center justify-between">
    <a
      href="/"
      name="go to home page"
      class="block rounded-full focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-link"
    >
      <svg
        viewBox="0 0 4167 4167"
        class="size-8"
        role="img"
        aria-label="Ryan Furrer"
        fill="none"
        stroke="#ed3f1c"
        stroke-width="208.33"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="2083.33" cy="2083.33" r="1875"></circle>
        <path
          d="M3409.16,757.508c365.871,365.872 68.83,1257 -662.913,1988.74c-731.743,731.743 -1622.87,1028.78 -1988.74,662.913c-365.871,-365.872 -68.83,-1257 662.913,-1988.74c731.743,-731.743 1622.87,-1028.78 1988.74,-662.913Z"
        ></path>
        <path
          d="M757.508,757.508c365.872,-365.871 1257,-68.83 1988.74,662.913c731.743,731.743 1028.78,1622.87 662.913,1988.74c-365.872,365.871 -1257,68.83 -1988.74,-662.913c-731.743,-731.743 -1028.78,-1622.87 -662.913,-1988.74Z"
        ></path>
      </svg>
    </a>
    <ul class="hidden items-center gap-1 text-sm sm:flex" role="list">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              name={`go to ${item.label.toLowerCase()} page`}
              data-dir-hover="nav"
              aria-current={isActive(item.href) ? "page" : undefined}
              class={cn(
                "block rounded-md px-3 py-1.5 font-medium transition-colors hover:text-foreground",
                isActive(item.href)
                  ? "bg-surface text-foreground"
                  : "text-foreground-muted",
              )}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="flex items-center gap-1 sm:gap-2">
      <div class="flex items-center rounded-md bg-secondary ps-2.5 md:gap-1">
        <Presence client:idle />
        <ModeToggle client:idle />
      </div>
      <div class="sm:hidden">
        <MobileNav client:load navItems={mobileNavItems} pathname={pathname} />
      </div>
    </div>
  </div>
</nav>
