---
import BackLink from "@/components/BackLink.astro";
import PortableText from "@/components/sanity/PortableText.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import TocMobile from "@/components/TocMobile.tsx";
import Layout from "@/layouts/Layout.astro";
import { extractHeadings, toStaticPaths } from "@/sanity/lib/content";
import { PROJECT_QUERY, PROJECT_SLUGS_QUERY } from "@/sanity/lib/queries";
import { urlForImage } from "@/sanity/lib/url-for-image";
import type {
  PROJECT_QUERY_RESULT,
  PROJECT_SLUGS_QUERY_RESULT,
} from "@/sanity/sanity.types";
import { formatDateLong } from "@/utils/date";
import { sanityClient } from "sanity:client";

export async function getStaticPaths() {
  const slugs = await sanityClient.fetch<PROJECT_SLUGS_QUERY_RESULT>(
    PROJECT_SLUGS_QUERY,
  );
  return toStaticPaths(slugs);
}

const project = await sanityClient.fetch<PROJECT_QUERY_RESULT>(
  PROJECT_QUERY,
  Astro.params,
);
if (!project) {
  throw new Error(`Project not found for slug: ${Astro.params.slug}`);
}

const headings = extractHeadings(project.body);

const projectImageUrl = project.headerImage
  ? urlForImage(project.headerImage).width(550).height(310).url()
  : null;
// OG card is generated at build time from the title/description
// (src/pages/og/work/[slug].png.ts) — no per-entry image to author.
const projectOgImageUrl = `/og/work/${Astro.params.slug}.png`;

const publishedLong = project.publishedAt
  ? formatDateLong(project.publishedAt)
  : null;
const updatedLong = project.updatedAt
  ? formatDateLong(project.updatedAt)
  : null;
// Only surface an "Updated" badge when it lands on a genuinely different day
// than publication — a same-day tidy-up would just show the same date twice.
const hasUpdate = !!(updatedLong && updatedLong !== publishedLong);

// The back link defaults to /work, but a project is only ever reached from one
// company hub — its own (or the "personal" bucket when it has no company). If
// the reader arrived from that hub, the client script below rewrites the back
// link to point there, so "back" returns them where they came from (§ spatial
// consistency) instead of dumping them on the full work index.
const companyBack = project.company?.slug
  ? {
      href: `/work/companies/${project.company.slug}`,
      label: `${project.company.name ?? project.company.slug} work`,
    }
  : { href: "/work/companies/personal", label: "Personal work" };
---

<Layout
  title={project.title}
  description={project.description}
  ogImage={projectOgImageUrl}
>
  <!-- Desktop: back link in left gutter -->
  <div slot="left" class="sticky top-20">
    <BackLink href="/work" label="Work" />
  </div>

  <!-- Desktop: ToC in right gutter -->
  <TableOfContents slot="right" headings={headings} />

  <!-- Center: article -->
  <main class="prose min-w-0 prose-neutral dark:prose-invert">
    <BackLink href="/work" label="Work" class="mb-6 lg:hidden" />
    {
      projectImageUrl && (
        <img src={projectImageUrl} alt={project.title} data-reveal />
      )
    }
    <header data-reveal>
      <h1 class="mb-3">{project.title}</h1>
      {
        publishedLong && (
          <p class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-sm text-foreground-subtle">
            <span>{publishedLong}</span>
            {hasUpdate && (
              <>
                <span aria-hidden="true" class="opacity-50">
                  ·
                </span>
                <span class="font-medium text-foreground-muted">
                  Updated {updatedLong}
                </span>
              </>
            )}
          </p>
        )
      }
      {
        (project.projectUrl || project.githubUrl) && (
          <div class="mt-4 flex flex-wrap gap-4">
            {project.projectUrl && (
              <a
                href={project.projectUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm"
              >
                Live Site
              </a>
            )}
            {project.githubUrl && (
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm"
              >
                GitHub
              </a>
            )}
          </div>
        )
      }
    </header>
    {
      project.description && (
        <p class="lead" data-reveal>
          {project.description}
        </p>
      )
    }
    {
      project.body && project.body.length > 0 && (
        <PortableText portableText={project.body} />
      )
    }
  </main>

  <!-- Mobile ToC drawer -->
  <TocMobile headings={headings} title={project.title ?? ""} client:load />

  {/* Referrer-aware back link: if the reader came from this project's company
      hub, point "back" there instead of the full work index. Falls back to the
      server-rendered /work default when there's no referrer or it's elsewhere. */}
  <script is:inline define:vars={{ companyBack }}>
    if (document.referrer) {
      try {
        const from = new URL(document.referrer);
        if (
          from.origin === location.origin &&
          from.pathname.startsWith("/work/companies/")
        ) {
          document.querySelectorAll("[data-back]").forEach((link) => {
            link.setAttribute("href", companyBack.href);
            const label = link.querySelector("[data-back-label]");
            if (label) label.textContent = companyBack.label;
          });
        }
      } catch {}
    }
  </script>
</Layout>
