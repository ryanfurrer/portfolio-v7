---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import BackToTop from "@/components/BackToTop.tsx";
import Footer from "@/components/Footer.astro";
import Head from "@/components/Head.astro";
import Navbar from "@/components/Navbar.astro";
import ScrollFade from "@/components/ScrollFade.astro";
import { cn } from "@/lib/utils";
import { SITE_TITLE, SITE_DESCRIPTION } from "@/consts";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noNavbar?: boolean;
  noFooter?: boolean;
  maxWidth?: "sm" | "lg";
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  ogImage,
  noNavbar = false,
  noFooter = false,
  maxWidth = "lg",
} = Astro.props;

// Back-to-top lives only on long-form content sections.
const contentPrefixes = ["/writing", "/work", "/appearances", "/now"];
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isContentPage = contentPrefixes.some(
  (p) => path === p || path.startsWith(`${p}/`),
);
---

<html lang="en">
  <Head title={title} description={description} ogImage={ogImage} />
  <body class="bg-background text-foreground-muted antialiased">
    <!-- Pinned to the page container's start edge (not the raw viewport edge),
         so it lines up with content instead of the far corner on wide screens. -->
    <div
      class="pointer-events-none fixed inset-x-0 top-4 z-50 mx-auto max-w-280 px-4"
    >
      <a
        href="#main-content"
        class="pointer-events-auto inline-block -translate-y-[calc(100%+1.5rem)] rounded-md bg-foreground px-4 py-2 text-sm font-medium text-background shadow-elevated transition-transform duration-200 ease-out focus:translate-y-0 motion-reduce:transition-none"
      >
        Skip to content
      </a>
    </div>
    <!-- Sticky header: transparent at the top, then a translucent blurred bar
         with a hairline border once scrolled (data-scrolled, set by
         sticky-header.ts). will-change:transform pins it to its own compositing
         layer so iOS Safari repaints it (and its backdrop-filter) smoothly during
         momentum scroll — otherwise it only redraws on scroll-up. -->
    {
      !noNavbar && (
        <header
          data-site-header
          class="group sticky top-0 z-40 border-b border-transparent transition-[border-color,translate] duration-300 ease-out data-hidden:-translate-y-full data-scrolled:border-border"
        >
          {/* Translucent glass lives on a dedicated background layer, NOT the
              header itself: a transformed / will-change *ancestor* disables
              backdrop-filter on descendants (e.g. the "Me" dropdown, which
              renders inside the header). Keeping the iOS compositing hint +
              blur on this sibling layer lets the menu blur the page while the
              header still repaints smoothly during iOS momentum scroll. */}
          <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-0 -z-10 transform-[translateZ(0)] bg-background/70 opacity-0 backdrop-blur-xl transition-opacity duration-300 ease-out will-change-transform group-data-[scrolled]:opacity-100"
          >
          </div>
          <div class="mx-auto max-w-280 px-4 lg:grid lg:grid-cols-[12rem_1fr_12rem] lg:gap-x-8">
            <div
              class={cn(
                "py-4 lg:col-start-2",
                maxWidth === "sm"
                  ? "mx-auto max-w-sm lg:mx-0 lg:max-w-none"
                  : "mx-auto max-w-2xl lg:mx-0 lg:max-w-none",
              )}
            >
              <Navbar />
            </div>
          </div>
        </header>
      )
    }

    <div
      class="mx-auto max-w-280 px-4 py-8 lg:grid lg:grid-cols-[12rem_1fr_12rem] lg:gap-x-8"
    >
      <!-- Left gutter -->
      <aside class="hidden lg:col-start-1 lg:block">
        <slot name="left" />
      </aside>

      <!-- Center: same width on every page -->
      <div
        id="main-content"
        tabindex="-1"
        class={cn(
          "space-y-16 min-w-0 focus:outline-none lg:col-start-2",
          maxWidth === "sm"
            ? "max-w-sm mx-auto lg:max-w-none lg:mx-0"
            : "max-w-2xl mx-auto lg:max-w-none lg:mx-0",
        )}
      >
        <slot />
        {isContentPage && <div id="content-end" aria-hidden="true" class="mt-0!"></div>}
        {!noFooter && <Footer />}
      </div>

      <!-- Right gutter -->
      <aside class="hidden lg:col-start-3 lg:block">
        <slot name="right" />
      </aside>
    </div>
    <ScrollFade />
    {isContentPage && <BackToTop client:load />}
    <Analytics />
    <SpeedInsights />
    <script>
      import "@/scripts/dir-hover";
      import "@/scripts/sticky-header";
      import "@/scripts/reveal";
      import "@/scripts/console-art";
    </script>
  </body>
</html>
