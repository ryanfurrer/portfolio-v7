---
import { sanityClient } from "sanity:client";
import Item from "@/components/Item.astro";
import Layout from "@/layouts/Layout.astro";
import { groupByYear } from "@/sanity/lib/content";
import { POSTS_QUERY } from "@/sanity/lib/queries";
import type { POSTS_QUERY_RESULT } from "@/sanity/sanity.types";
import { SECTION_META } from "@/lib/og/sections";

const posts = await sanityClient.fetch<POSTS_QUERY_RESULT>(POSTS_QUERY);
const { byYear: postsByYear, years } = groupByYear(posts);

const description = SECTION_META.writing.description;
---

<Layout
  title="Writing — Ryan Furrer"
  description={description}
  ogImage="/og/writing.png"
>
  <div class="space-y-8">
    <header class="space-y-3">
      <h1 class="text-2xl text-balance text-foreground sm:text-3xl" data-reveal>
        Writing
      </h1>
      <p class="lead max-w-[60ch]" data-reveal>
        {description}
      </p>
    </header>
    <main>
      <div class="space-y-8">
        {
          years.map((year) => (
            <section class="space-y-4">
              <h2 class="small-heading" data-reveal>
                {year}
              </h2>
              <ul class="flex flex-col gap-px" role="list">
                {postsByYear[year].map((post) => (
                  <li>
                    <Item
                      title={post.title}
                      href={`/writing/${post.slug?.current}`}
                      publishedAt={post.publishedAt}
                    />
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </main>
  </div>
</Layout>
