---
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import { extractHeadings, toStaticPaths } from "@/sanity/lib/content";
import { POST_QUERY, POST_SLUGS_QUERY } from "@/sanity/lib/queries";
import { articleHeaderImage } from "@/sanity/lib/url-for-image";
import type {
  POST_QUERY_RESULT,
  POST_SLUGS_QUERY_RESULT,
} from "@/sanity/sanity.types";
import { sanityClient } from "sanity:client";

export async function getStaticPaths() {
  const slugs =
    await sanityClient.fetch<POST_SLUGS_QUERY_RESULT>(POST_SLUGS_QUERY);
  return toStaticPaths(slugs);
}

const post = await sanityClient.fetch<POST_QUERY_RESULT>(
  POST_QUERY,
  Astro.params,
);
if (!post) throw new Error(`Post not found for slug: ${Astro.params.slug}`);

const headings = extractHeadings(post.body);
const headerImage = post.headerImage
  ? articleHeaderImage(post.headerImage)
  : null;
// OG card is generated at build time from the title/description
// (src/pages/og/writing/[slug].png.ts) — no per-entry image to author.
---

<ArticleLayout
  title={post.title}
  description={post.description}
  ogImage={`/og/writing/${Astro.params.slug}.png`}
  headerImage={headerImage}
  publishedAt={post.publishedAt}
  updatedAt={post.updatedAt}
  headings={headings}
  body={post.body}
  backHref="/writing"
  backLabel="Writing"
  schemaType="BlogPosting"
/>
