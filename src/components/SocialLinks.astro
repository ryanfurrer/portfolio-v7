---
import { socialLinks } from "@/lib/social-links";

interface Props {
  orientation?: "horizontal" | "vertical";
}

const { orientation = "horizontal" } = Astro.props;

const footerLinks = socialLinks.filter((link) => link.footer);
---

<ul
  role="list"
  class:list={orientation === "vertical"
    ? "flex flex-col gap-y-4 md:gap-y-2"
    : "flex gap-x-4 md:gap-x-2"}
>
  {
    footerLinks.map((link) => (
      <li>
        <a href={link.href} class="quiet-link no-underline">
          {link.label}
        </a>
      </li>
    ))
  }
</ul>
