---
import { sanityClient } from "sanity:client";
import EmptyState from "@/components/EmptyState.astro";
import Item from "@/components/Item.astro";
import Layout from "@/layouts/Layout.astro";
import { groupByYear } from "@/sanity/lib/content";
import { PROJECTS_QUERY } from "@/sanity/lib/queries";
import type { PROJECTS_QUERY_RESULT } from "@/sanity/sanity.types";
import { SECTION_META } from "@/lib/og/sections";

const projects = await sanityClient.fetch<PROJECTS_QUERY_RESULT>(PROJECTS_QUERY);
const { byYear: projectsByYear, years } = groupByYear(projects);

const description = SECTION_META.work.description;

const showEarlyState = projects.length <= 1;

// Build the tag chips from the projects we already have: one per distinct
// company, plus a "Personal" bucket for projects with no company. Each links
// to its /work/companies/* hub.
const companyTags = new Map<string, string>();
let hasPersonal = false;
for (const project of projects) {
  if (project.company?.slug) {
    companyTags.set(project.company.slug, project.company.name ?? project.company.slug);
  } else {
    hasPersonal = true;
  }
}
const tags = [
  ...[...companyTags].map(([slug, name]) => ({ slug, name })),
  ...(hasPersonal ? [{ slug: "personal", name: "Personal" }] : []),
];
---

<Layout
  title="Work — Ryan Furrer"
  description={description}
  ogImage="/og/work.png"
>
  <div class="space-y-8">
    <header class="space-y-3">
      <h1 class="text-2xl text-balance text-foreground sm:text-3xl" data-reveal>
        Work
      </h1>
      <p class="lead max-w-[60ch]" data-reveal>
        {description}
      </p>
      {
        tags.length > 1 && (
          <nav aria-label="Filter work by tag" class="flex flex-wrap gap-2 pt-1">
            {tags.map((tag) => (
              <a
                href={`/work/companies/${tag.slug}`}
                class="rounded-md border border-border bg-surface px-3 py-1 text-sm text-foreground-muted no-underline transition hover:bg-surface-hover hover:text-foreground"
                data-reveal
              >
                {tag.name}
              </a>
            ))}
          </nav>
        )
      }
    </header>
    <main>
      <div class="space-y-8">
        {
          years.map((year) => (
            <section class="space-y-4">
              <h2 class="small-heading" data-reveal>
                {year}
              </h2>
              <ul class="flex flex-col gap-px" role="list">
                {projectsByYear[year].map((project) => (
                  <li>
                    <Item
                      title={project.title}
                      href={`/work/${project.slug?.current}`}
                      publishedAt={project.publishedAt}
                    />
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
        {
          showEarlyState && (
            <EmptyState class="max-w-[60ch] text-sm" reveal={false}>
              More projects are on the way. In the meantime, this is where it
              started.
            </EmptyState>
          )
        }
      </div>
    </main>
  </div>
</Layout>
