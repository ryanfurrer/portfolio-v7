---
import { Code } from "astro:components";

const { node } = Astro.props;
const { code, language } = node;

// Default to 'text' if language is not specified
const lang = language || "text";
---

{
  /* A code block can be empty before any code is typed (e.g. editing a draft in
     the Studio with preview on). Guard so Shiki doesn't crash on `undefined`. */
  code && (
    <Code
      code={code}
      lang={lang}
      themes={{ light: "catppuccin-latte", dark: "catppuccin-mocha" }}
      wrap={true}
    />
  )
}
