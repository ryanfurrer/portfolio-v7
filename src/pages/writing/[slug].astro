---
import BackLink from "@/components/BackLink.astro";
import PortableText from "@/components/sanity/PortableText.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import TocMobile from "@/components/TocMobile.tsx";
import Layout from "@/layouts/Layout.astro";
import {
  extractHeadings,
  prependDescription,
  toStaticPaths,
} from "@/sanity/lib/content";
import { POST_QUERY, POST_SLUGS_QUERY } from "@/sanity/lib/queries";
import { urlForImage } from "@/sanity/lib/url-for-image";
import type {
  POST_QUERY_RESULT,
  POST_SLUGS_QUERY_RESULT,
} from "@/sanity/sanity.types";
import { formatDateLong } from "@/utils/date";
import { sanityClient } from "sanity:client";

export async function getStaticPaths() {
  const slugs =
    await sanityClient.fetch<POST_SLUGS_QUERY_RESULT>(POST_SLUGS_QUERY);
  return toStaticPaths(slugs);
}

const post = await sanityClient.fetch<POST_QUERY_RESULT>(
  POST_QUERY,
  Astro.params,
);
if (!post) throw new Error(`Post not found for slug: ${Astro.params.slug}`);

const bodyWithDescription = prependDescription(post.body, post.description);
const headings = extractHeadings(post.body);

const postImageUrl = post.headerImage
  ? urlForImage(post.headerImage).width(550).height(310).url()
  : null;
const postOgImageUrl = post.ogImage
  ? urlForImage(post.ogImage).width(1200).height(630).url()
  : undefined;

const publishedLong = post.publishedAt
  ? formatDateLong(post.publishedAt)
  : null;
const updatedLong = post.updatedAt ? formatDateLong(post.updatedAt) : null;
---

<Layout
  title={post.title}
  description={post.description}
  ogImage={postOgImageUrl}
>
  <!-- Desktop: back link in left gutter -->
  <div slot="left" class="sticky top-20">
    <BackLink href="/writing" label="Writing" />
  </div>

  <!-- Desktop: ToC in right gutter -->
  <TableOfContents slot="right" headings={headings} />

  <!-- Center: article -->
  <main class="prose min-w-0 prose-neutral dark:prose-invert">
    <BackLink href="/writing" label="Writing" class="mb-6 lg:hidden" />
    {postImageUrl && <img src={postImageUrl} alt={post.title} data-reveal />}
    <header data-reveal>
      <h1 class="mb-1">{post.title}</h1>
      {
        publishedLong && !updatedLong && (
          <span class="text-sm text-foreground-subtle">{publishedLong}</span>
        )
      }
      {
        updatedLong && (
          <div class="flex flex-col gap-y-1">
            <span class="text-sm text-foreground-subtle">
              Originally published: {publishedLong}
            </span>
            <span class="badge w-fit">Updated {updatedLong}</span>
          </div>
        )
      }
    </header>
    {
      bodyWithDescription.length > 0 && (
        <PortableText portableText={bodyWithDescription} />
      )
    }
  </main>

  <!-- Mobile ToC drawer -->
  <TocMobile headings={headings} title={post.title ?? ""} client:load />
</Layout>
