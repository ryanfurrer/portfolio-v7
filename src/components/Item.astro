---
import { formatDateDotNotation } from "@/utils/date";

interface Props {
  title: string | null;
  href: string;
  publishedAt?: string | null;
}

const { title, href, publishedAt } = Astro.props;

const formattedDate = publishedAt ? formatDateDotNotation(publishedAt) : null;
---

<a
  href={href}
  data-dir-hover="item"
  data-reveal
  class="group/item -mx-2 block rounded-md p-2 font-normal no-underline transition duration-200 ease-out [-webkit-tap-highlight-color:transparent] active:scale-[0.98] md:mx-0 md:p-2"
>
  <div class="w-full items-center justify-between gap-4 md:flex">
    <div class="w-fit text-foreground">
      <h3 class="font-semibold">{title}</h3>
    </div>
    <div class="hidden min-w-4 flex-1 border-b md:block"></div>
    {
      formattedDate && (
        <div class="font-mono-custom w-fit">
          <span class="transition-colors group-hover/item:text-foreground">
            {formattedDate}
          </span>
        </div>
      )
    }
  </div>
</a>
