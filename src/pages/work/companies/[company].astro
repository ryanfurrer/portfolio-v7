---
import BackLink from "@/components/BackLink.astro";
import CompanyHeader from "@/components/CompanyHeader.astro";
import Item from "@/components/Item.astro";
import Layout from "@/layouts/Layout.astro";
import { groupByYear } from "@/sanity/lib/content";
import { WORK_HUBS_QUERY } from "@/sanity/lib/queries";
import type { WORK_HUBS_QUERY_RESULT } from "@/sanity/sanity.types";
import { sanityClient } from "sanity:client";

// One hub per company that has projects, plus a derived "personal" bucket
// (projects with no company). Nested under /work/companies/* so it can't
// collide with the /work/[slug] project-detail route (two bare [param]
// routes at the same level is an Astro build error).
export async function getStaticPaths() {
  const { companies, personal } =
    await sanityClient.fetch<WORK_HUBS_QUERY_RESULT>(WORK_HUBS_QUERY);

  const paths = companies
    .filter((c) => c.slug && c.projects.length > 0)
    .map((c) => ({
      params: { company: c.slug as string },
      props: {
        label: c.name ?? (c.slug as string),
        url: c.url,
        description: c.description,
        logo: c.logo,
        projects: c.projects,
      },
    }));

  if (personal.length > 0) {
    paths.push({
      params: { company: "personal" },
      props: {
        label: "Personal",
        url: null,
        description:
          "Things I've built for myself — side projects and experiments.",
        logo: null,
        projects: personal,
      },
    });
  }

  return paths;
}

const { label, url, description, logo, projects } = Astro.props;
const { byYear, years } = groupByYear(projects);

const metaDescription = description ?? `Work for ${label}`;
---

<Layout title={`${label} — Work — Ryan Furrer`} description={metaDescription}>
  <!-- Desktop: back link in left gutter -->
  <div slot="left" class="sticky top-20">
    <BackLink href="/work" label="Work" />
  </div>

  <div class="space-y-8">
    <BackLink href="/work" label="Work" class="lg:hidden" />
    <CompanyHeader
      label={label}
      url={url}
      description={description}
      logo={logo}
    />
    <main>
      <div class="space-y-8">
        {
          years.map((year) => (
            <section class="space-y-4">
              <h2 class="small-heading text-sm md:px-2" data-reveal>
                {year}
              </h2>
              <ul class="flex flex-col gap-px" role="list">
                {byYear[year].map((project) => (
                  <li>
                    <Item
                      title={project.title}
                      href={`/work/${project.slug?.current}`}
                      publishedAt={project.publishedAt}
                    />
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </main>
  </div>
</Layout>
