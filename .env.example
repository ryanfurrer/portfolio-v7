# Copy to `.env` (gitignored) and fill in.

# Sanity read token with the "Viewer" role — lets the local dev server
# (`pnpm dev`) read unpublished/edited content for preview. Create one at
# https://www.sanity.io/manage  →  your project  →  API  →  Tokens  →  Add token
# (name it e.g. "draft-preview", role: Viewer). This is a SECRET: never commit
# it, and it is only ever used locally — production builds don't read it.
SANITY_API_READ_TOKEN=
