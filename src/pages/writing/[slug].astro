---
import BackLink from "@/components/BackLink.astro";
import PortableText from "@/components/sanity/PortableText.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import TocMobile from "@/components/TocMobile.tsx";
import Layout from "@/layouts/Layout.astro";
import { slugify, textToPortableTextBlock } from "@/lib/utils";
import { formatDateLong } from "@/utils/date";
import type { SanityDocument } from "@sanity/client";
import {
  createImageUrlBuilder,
  type SanityImageSource,
} from "@sanity/image-url";
import { sanityClient } from "sanity:client";

const POST_QUERY = `*[_type == "post" && slug.current == $slug][0]{
  ...,
  tags[]->{name, slug}
}`;
const post = await sanityClient.fetch<SanityDocument>(POST_QUERY, Astro.params);

// Prepend description as first paragraph in body
let bodyWithDescription = Array.isArray(post.body) ? [...post.body] : [];
if (post.description && typeof post.description === "string") {
  const descriptionBlock = textToPortableTextBlock(post.description);
  bodyWithDescription = [descriptionBlock, ...bodyWithDescription];
}

export async function getStaticPaths(): Promise<{ params: { slug: string } }> {
  const SLUGS_QUERY = `*[_type == "post" && defined(slug.current)]{
    "params": {"slug": slug.current}
  }`;
  return await sanityClient.fetch(SLUGS_QUERY, Astro.params);
}

const { projectId, dataset } = sanityClient.config();
const urlFor = (source: SanityImageSource) =>
  projectId && dataset
    ? createImageUrlBuilder({ projectId, dataset }).image(source)
    : null;
const postImageUrl = post.headerImage
  ? urlFor(post.headerImage)?.width(550).height(310).url()
  : null;
const postOgImageUrl = post.ogImage
  ? urlFor(post.ogImage)?.width(1200).height(630).url()
  : undefined;

// Extract headings for ToC
interface HeadingBlock {
  _type: string;
  style: string;
  children: Array<{ text?: string }>;
}
const headings = (post.body ?? [])
  .filter(
    (b: HeadingBlock) =>
      b._type === "block" && ["h2", "h3", "h4"].includes(b.style),
  )
  .map((b: HeadingBlock) => {
    const text = b.children.map((c) => c.text ?? "").join("");
    return {
      id: slugify(text),
      text,
      level: parseInt(b.style.replace("h", ""), 10),
    };
  });
---

<Layout
  title={post.title}
  description={post.description}
  ogImage={postOgImageUrl}
>
  <!-- Desktop: back link in left gutter -->
  <div slot="left" class="sticky top-20">
    <BackLink href="/writing" label="Writing" />
  </div>

  <!-- Desktop: ToC in right gutter -->
  <TableOfContents slot="right" headings={headings} />

  <!-- Center: article -->
  <main class="prose min-w-0 prose-neutral dark:prose-invert">
    <BackLink href="/writing" label="Writing" class="mb-6 lg:hidden" />
    {postImageUrl && <img src={postImageUrl} alt={post.title} data-reveal />}
    <header data-reveal>
      <h1 class="mb-1">{post.title}</h1>
      {
        post.publishedAt && !post.updatedAt && (
          <span class="text-sm text-foreground-subtle">
            {formatDateLong(post.publishedAt)}
          </span>
        )
      }
      {
        post.updatedAt && (
          <div class="flex flex-col gap-y-1">
            <span class="text-sm text-foreground-subtle">
              Originally published: {formatDateLong(post.publishedAt)}
            </span>
            <span class="badge w-fit">
              Updated {formatDateLong(post.updatedAt)}
            </span>
          </div>
        )
      }
    </header>
    {
      bodyWithDescription.length > 0 && (
        <PortableText portableText={bodyWithDescription} />
      )
    }
  </main>

  <!-- Mobile ToC drawer -->
  <TocMobile headings={headings} title={post.title} client:load />
</Layout>
