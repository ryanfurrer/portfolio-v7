---
import PortableText from "@/components/sanity/PortableText.astro";
import Signature from "@/components/Signature.astro";
import Layout from "@/layouts/Layout.astro";
import { ABOUT_QUERY } from "@/sanity/lib/queries";
import type { ABOUT_QUERY_RESULT } from "@/sanity/sanity.types";
import { sanityClient } from "sanity:client";

const about = await sanityClient.fetch<ABOUT_QUERY_RESULT>(ABOUT_QUERY);

const title = about?.title ?? "About";
const description =
  about?.description ?? "The short version of a longer story.";
const body = about?.body ?? [];
---

<Layout
  title={`${title} — Ryan Furrer`}
  description={description}
  ogImage="/og/about.png"
>
  <div class="space-y-8 md:px-2">
    <header class="space-y-3">
      <h1 class="text-2xl text-balance text-foreground sm:text-3xl" data-reveal>
        {title}
      </h1>
      <p class="lead max-w-[60ch]" data-reveal>
        {description}
      </p>
    </header>
    <main class="space-y-4" data-reveal>
      {body.length > 0 && <PortableText portableText={body} />}
      <Signature />
    </main>
  </div>
</Layout>
