---
import PortableText from "@/components/sanity/PortableText.astro";
import Layout from "@/layouts/Layout.astro";
import { NOW_QUERY } from "@/sanity/lib/queries";
import type { NOW_QUERY_RESULT } from "@/sanity/sanity.types";
import { formatDateLong } from "@/utils/date";
import { sanityClient } from "sanity:client";

const title = "Now";
const description = "What I'm up to currently";

// Newest entry is the live "Now" card; the rest become "Previously".
const entries = await sanityClient.fetch<NOW_QUERY_RESULT>(NOW_QUERY);
---

<Layout title={title} description={description}>
  <div class="space-y-8">
    <header class="space-y-3 md:px-2">
      <h1 class="text-2xl text-balance text-foreground sm:text-3xl" data-reveal>
        {title}
      </h1>
      <p class="lead max-w-[60ch]" data-reveal>
        {description}
      </p>
    </header>
    <main class="space-y-6 md:px-2">
      {
        entries.map((entry, i) => {
          const dateLong = entry.publishedAt
            ? formatDateLong(entry.publishedAt)
            : null;
          const dateIso = entry.publishedAt?.slice(0, 10);
          return (
            <article class="now-card" data-reveal>
              <header class="now-head flex items-baseline justify-between gap-4">
                <span class="small-heading">
                  {i === 0 ? "Now" : "Previously"}
                </span>
                {dateLong && (
                  <time
                    datetime={dateIso}
                    class="text-sm font-medium text-foreground-muted"
                  >
                    {dateLong}
                  </time>
                )}
              </header>
              {entry.body && entry.body.length > 0 && (
                <div class="now-body">
                  <PortableText portableText={entry.body} />
                </div>
              )}
              {entry.media && entry.media.length > 0 && (
                <dl class="now-meta">
                  {entry.media.map((row) => (
                    <div class="now-row flex flex-col sm:flex-row sm:gap-4">
                      <dt class="small-heading shrink-0 sm:w-28">
                        {row.label}
                      </dt>
                      <dd class="flex-1 text-pretty">
                        {row.value && row.value.length > 0 && (
                          <PortableText portableText={row.value} />
                        )}
                      </dd>
                    </div>
                  ))}
                </dl>
              )}
            </article>
          );
        })
      }
      {
        entries.length === 0 && (
          <p class="text-pretty text-foreground-subtle md:px-2">
            Nothing here yet — check back soon.
          </p>
        )
      }
    </main>
  </div>
</Layout>

<style>
  /* Ruled-notebook "journal page" cards.
     Everything sits on one baseline grid: every line-height and every vertical
     gap is a multiple of --r, and the horizontal rules repeat every --r at the
     text baseline (--baseline), so the writing lands ON the lines. Bright-white
     paper is defined by the hairline + soft shadow + rules; a faint left margin
     rule (tied to the accent) runs down the side. */
  .now-card {
    --r: 1.75rem; /* the single rhythm unit */
    --baseline: 1.32rem; /* where the rule sits within a line (≈ text baseline) */
    line-height: var(--r);
    padding-block: var(--r);
    /* inline-start gets the wide gutter for the margin rule (see note below). */
    padding-inline: 3rem 1.5rem;
    background-color: oklch(0.999 0 0);
    /* A single tiled rule line (via background-size/-repeat) rather than
       repeating-linear-gradient — WebKit drops thin repeating bands partway
       down a tall element, so the lines would stop rendering in Safari. */
    /* College-ruled (light): a subdued rose margin rule + subdued blue
       horizontal rules — US-notebook nod, dialed back from a real sheet.
       (Dark mode stays fully neutral: see the .dark block below.) */
    background-image:
      linear-gradient(
        to right,
        transparent 0 2.25rem,
        color-mix(in oklch, oklch(0.63 0.16 22) 55%, transparent) 2.25rem
          2.28rem,
        transparent 2.28rem
      ),
      linear-gradient(
        to bottom,
        oklch(0.6 0.1 245 / 0.32) 0 1px,
        transparent 1px
      );
    background-size:
      100% 100%,
      100% var(--r);
    background-repeat: no-repeat, repeat;
    background-position:
      0 0,
      0 var(--baseline);
    border: 1px solid oklch(0 0 0 / 0.07);
    border-radius: 0.6rem;
    box-shadow:
      0 1px 2px oklch(0 0 0 / 0.05),
      0 12px 32px -18px oklch(0 0 0 / 0.18);
  }

  /* Lock every line to the rhythm. */
  .now-card :is(p, dt, dd, span, time, a) {
    line-height: var(--r);
  }

  /* All vertical spacing is a whole number of rule lines so nothing drifts. */
  .now-card > * + *,
  .now-body > * + * {
    margin-top: var(--r);
  }
  .now-row + .now-row {
    margin-top: 0; /* rows flow line-by-line, like list entries on the page */
  }

  /* Inside the cards the "writing" reads as a single ink color: body copy and
     its values use the foreground, and links drop the accent — the underline
     alone marks them. (Eyebrow, date, and category labels keep their styling.) */
  .now-body,
  .now-row dd {
    color: var(--color-foreground);
  }
  .now-card :is(.now-body, .now-row dd) a {
    color: var(--color-foreground);
    text-decoration-color: color-mix(
      in oklch,
      var(--color-foreground) 40%,
      transparent
    );
  }
  .now-card :is(.now-body, .now-row dd) a:hover {
    color: var(--color-foreground);
    text-decoration-color: currentColor;
  }

  :global(.dark) .now-card {
    background-color: oklch(0.21 0 0);
    background-image:
      linear-gradient(
        to right,
        transparent 0 2.25rem,
        color-mix(in oklch, var(--link) 42%, transparent) 2.25rem 2.28rem,
        transparent 2.28rem
      ),
      linear-gradient(to bottom, oklch(0.92 0 0 / 0.07) 0 1px, transparent 1px);
    border-color: oklch(1 0 0 / 0.08);
    box-shadow: none;
  }
</style>
