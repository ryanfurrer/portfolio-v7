---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Ryan Furrer — Frontend Engineer and Designer",
  description = "Frontend Engineer who loves working at the crossroads of design and engineering.",
  ogImage,
} = Astro.props;

const ogUrl = new URL(Astro.url.pathname, Astro.site).toString();
const defaultOgImage = new URL("/og-image.png", Astro.site).toString();
const ogImageUrl = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : new URL(ogImage, Astro.site).toString()
  : defaultOgImage;
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  {/* Arm the entrance reveal before paint so [data-reveal] content starts
      hidden — but only when JS is on and motion is allowed. See
      scripts/reveal.ts. */}
  <script is:inline>
    (() => {
      try {
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        document.documentElement.classList.add("reveal-init");
      } catch {}
    })();
  </script>
  <meta
    name="theme-color"
    media="(prefers-color-scheme: light)"
    content="#ffffff"
  />
  <meta
    name="theme-color"
    media="(prefers-color-scheme: dark)"
    content="#1a1a1a"
  />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link
    rel="preload"
    href="/assets/fonts/Geist[wght].woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href="/assets/fonts/Geist-Italic[wght].woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href="/assets/fonts/GeistMono[wght].woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  <link
    rel="preload"
    href="/assets/fonts/PermanentMarker-Regular.ttf"
    as="font"
    type="font/ttf"
    crossorigin
  />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={ogUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImageUrl} />
</head>
