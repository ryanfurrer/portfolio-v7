---
import { PortableText as PortableTextInternal } from "astro-portabletext";
import PortableTextImage from "./PortableTextImage.astro";
import CodeBlock from "./CodeBlock.astro";
import CalloutBlock from "./CalloutBlock.astro";
import HeadingBlock from "./HeadingBlock.astro";
import YouTubeEmbed from "./YouTubeEmbed.astro";
import PortableTextVideo from "./PortableTextVideo.astro";
import PortableTextLink from "./PortableTextLink.astro";

const { portableText } = Astro.props;

const components = {
  type: {
    image: PortableTextImage,
    code: CodeBlock,
    callout: CalloutBlock,
    youtube: YouTubeEmbed,
    video: PortableTextVideo,
  },
  block: {
    h2: HeadingBlock,
    h3: HeadingBlock,
    h4: HeadingBlock,
  },
  mark: {
    link: PortableTextLink,
  },
};
---

<PortableTextInternal value={portableText ?? []} components={components} />
