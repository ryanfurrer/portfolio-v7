---
import Item from "@/components/Item.astro";
import Layout from "@/layouts/Layout.astro";
import { resolveUsesIcon } from "@/lib/uses-icons";
import { USES_QUERY } from "@/sanity/lib/queries";
import type { USES_QUERY_RESULT } from "@/sanity/sanity.types";
import { sanityClient } from "sanity:client";

const uses = await sanityClient.fetch<USES_QUERY_RESULT>(USES_QUERY);

const title = uses?.title ?? "Uses";
const description =
  uses?.description ?? "The tools, toys, and setup I rely on daily.";

// Only render categories that actually have items.
const categories = (uses?.categories ?? []).filter(
  (category) => (category.items?.length ?? 0) > 0,
);
---

<Layout
  title={`${title} — Ryan Furrer`}
  description={description}
  ogImage="/og/uses.png"
>
  <div class="space-y-8">
    <header class="space-y-3 md:px-2">
      <h1 class="text-2xl text-balance text-foreground sm:text-3xl" data-reveal>
        {title}
      </h1>
      <p class="lead max-w-[60ch]" data-reveal>
        {description}
      </p>
    </header>

    <main class="space-y-10">
      {
        categories.map((category) => (
          <section class="space-y-2">
            <h2 class="small-heading md:px-2" data-reveal>
              {category.title}
            </h2>
            <ul class="flex flex-col gap-px" role="list">
              {category.items?.map((item) => (
                <li>
                  <Item
                    title={item.name}
                    href={item.url ?? undefined}
                    external={Boolean(item.url)}
                  >
                    <svg
                      slot="leading"
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="size-4"
                      aria-hidden="true"
                      set:html={resolveUsesIcon(item.icon, item.description)}
                    />
                    {item.description && (
                      <span
                        slot="trailing"
                        class="font-mono-custom text-xs uppercase tracking-wide text-foreground-muted transition-colors group-hover/item:text-foreground"
                      >
                        {item.description}
                      </span>
                    )}
                  </Item>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
      {
        categories.length === 0 && (
          <p class="text-pretty text-foreground-subtle md:px-2" data-reveal>
            Nothing here yet — check back soon.
          </p>
        )
      }
    </main>
  </div>
</Layout>
