---
import { cn } from "@/lib/utils";

interface Props {
  href?: string;
  variant?: "default" | "square";
  class?: string;
}

const { href, variant = "default", class: className } = Astro.props;

const baseClasses =
  "block rounded-lg p-2 transition duration-200 ease-out active:scale-97 links-card no-underline size-full";
const variantClasses =
  variant === "square"
    ? "aspect-square squircle rounded-3xl border bg-card p-4 hover:saturate-150 dark:hover:brightness-105 dark:focus:brightness-105 focus:saturate-150 focus:scale-102"
    : "card-raised";
const classes = cn(baseClasses, variantClasses, className);
---

{
  href ? (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class={classes}
      data-reveal
    >
      <slot />
    </a>
  ) : (
    <div class={classes} data-reveal>
      <slot />
    </div>
  )
}
