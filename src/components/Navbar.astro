---
import MobileNav from "@/components/MobileNav";
import { cn } from "@/lib/utils";

const navItems = [
  {
    label: "Writing",
    href: "/writing",
  },
  {
    label: "Work",
    href: "/work",
  },
  {
    label: "Appearances",
    href: "/appearances",
  },
  {
    label: "Now",
    href: "/now",
  },
  {
    label: "About",
    href: "/about",
  },
];

// Mobile menu leads with Home since the logo is the only desktop home affordance.
const mobileNavItems = [{ label: "Home", href: "/" }, ...navItems];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(`${href}/`);
---

<nav class="mb-16 md:px-2">
  <div class="flex items-center justify-between">
    <a
      href="/"
      name="go to home page"
      class="rounded-[10px] transition-opacity hover:opacity-80 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-link"
    >
      <span
        class="squircle flex size-8 items-center justify-center rounded-[10px] bg-foreground text-[0.8125rem] font-semibold tracking-tight text-background lowercase"
        aria-label="Ryan Furrer"
        role="img"
      >
        rf
      </span>
    </a>
    <ul class="hidden items-center gap-1 text-sm sm:flex" role="list">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              name={`go to ${item.label.toLowerCase()} page`}
              aria-current={isActive(item.href) ? "page" : undefined}
              class={cn(
                "block rounded-md px-3 py-1.5 font-medium transition-colors hover:bg-surface hover:text-foreground",
                isActive(item.href)
                  ? "bg-surface text-foreground"
                  : "text-foreground-muted",
              )}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="sm:hidden">
      <MobileNav client:load navItems={mobileNavItems} pathname={pathname} />
    </div>
  </div>
</nav>
