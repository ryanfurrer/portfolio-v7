---
import { Code } from "astro:components";

const { node } = Astro.props;
const { code, language } = node;

// Default to 'text' if language is not specified
const lang = language || "text";
---

{
  /* A code block can be empty before any code is typed (e.g. editing a draft in
     the Studio with preview on). Guard so Shiki doesn't crash on `undefined`. */
  code && (
    <div class="code-surface" data-code={code}>
      <button type="button" class="code-copy" aria-label="Copy code">
        {/* Two inline Lucide icons; CSS swaps them on the copied state. */}
        <svg
          class="code-copy-icon code-copy-icon--copy"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
        </svg>
        <svg
          class="code-copy-icon code-copy-icon--check"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M20 6 9 17l-5-5" />
        </svg>
      </button>
      <Code
        code={code}
        lang={lang}
        themes={{ light: "catppuccin-latte", dark: "catppuccin-mocha" }}
        wrap={true}
      />
      {/* Polite live region so the copy result is announced to screen readers. */}
      <span class="sr-only" role="status" aria-live="polite" />
    </div>
  )
}

<script>
  // One delegated listener handles every code block on the page. The copied
  // text comes from the block's `data-code` (the exact Portable Text source),
  // not the highlighted/soft-wrapped DOM, so it's always exact.
  const RESET_MS = 2000;
  const timers = new WeakMap<HTMLElement, number>();

  document.addEventListener("click", async (event) => {
    const btn = (event.target as HTMLElement)?.closest<HTMLButtonElement>(
      ".code-copy",
    );
    if (!btn) return;

    const surface = btn.closest<HTMLElement>(".code-surface");
    const code = surface?.dataset.code;
    const status = surface?.querySelector<HTMLElement>('[role="status"]');
    if (!surface || code == null) return;

    try {
      await navigator.clipboard.writeText(code);
      surface.dataset.copied = "true";
      btn.setAttribute("aria-label", "Copied");
      if (status) status.textContent = "Copied to clipboard";
    } catch {
      btn.setAttribute("aria-label", "Copy failed");
      if (status) status.textContent = "Copy failed";
    }

    // Reset the visual + label state after the feedback window.
    window.clearTimeout(timers.get(btn));
    timers.set(
      btn,
      window.setTimeout(() => {
        delete surface.dataset.copied;
        btn.setAttribute("aria-label", "Copy code");
        if (status) status.textContent = "";
      }, RESET_MS),
    );
  });
</script>

<style>
  .code-surface {
    position: relative;
  }

  .code-copy {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 0;
    border-radius: 0.5rem;
    color: color-mix(in oklch, currentColor 70%, transparent);
    background: color-mix(in oklch, var(--surface) 75%, transparent);
    backdrop-filter: blur(4px);
    cursor: pointer;
    opacity: 0;
    transition:
      opacity 150ms ease,
      color 150ms ease;
  }

  /* Reveal on hover/focus within the block, and always while showing feedback
     (so the confirmation isn't hidden the moment the pointer leaves). */
  .code-surface:hover .code-copy,
  .code-surface:focus-within .code-copy,
  .code-surface[data-copied] .code-copy {
    opacity: 1;
  }

  .code-copy:hover {
    color: currentColor;
  }

  .code-copy:focus-visible {
    outline: 2px solid var(--color-brand, currentColor);
    outline-offset: 2px;
    opacity: 1;
  }

  .code-copy-icon {
    width: 1rem;
    height: 1rem;
  }

  /* Show the check only once copied; the copy icon otherwise. */
  .code-copy-icon--check {
    display: none;
  }

  .code-surface[data-copied] .code-copy {
    color: var(--color-brand, currentColor);
  }

  .code-surface[data-copied] .code-copy-icon--copy {
    display: none;
  }

  .code-surface[data-copied] .code-copy-icon--check {
    display: block;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .code-copy {
      transition: none;
    }
  }

  /* On touch (no hover), keep the button visible — there's no hover to reveal
     it. Coarse pointers get a persistent, slightly subdued control. */
  @media (hover: none) {
    .code-copy {
      opacity: 0.7;
    }
  }
</style>
