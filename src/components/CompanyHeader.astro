---
import CtaLink from "@/components/CtaLink.astro";
import { urlForImage } from "@/sanity/lib/url-for-image";
import type { WORK_HUBS_QUERY_RESULT } from "@/sanity/sanity.types";

type Company = WORK_HUBS_QUERY_RESULT["companies"][number];

interface Props {
  label: string;
  url: Company["url"];
  description: Company["description"];
  logo: Company["logo"];
}

const { label, url, description, logo } = Astro.props;

const logoUrl = logo
  ? urlForImage(logo).width(80).height(80).fit("max").url()
  : null;
---

<header class="space-y-3">
  <div class="flex items-center gap-2.5 text-2xl sm:text-3xl">
    {
      logoUrl && (
        <img
          src={logoUrl}
          alt={`${label} logo`}
          width="40"
          height="40"
          class="size-[1em] shrink-0 object-contain"
          data-reveal
        />
      )
    }
    <h1 class="text-balance text-foreground" data-reveal>
      {label}
    </h1>
  </div>
  {
    description && (
      <p class="lead max-w-[60ch]" data-reveal>
        {description}
      </p>
    )
  }
  {
    url && (
      <CtaLink href={url} direction="external" data-reveal>
        Visit website
      </CtaLink>
    )
  }
</header>
