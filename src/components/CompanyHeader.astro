---
import { urlForImage } from "@/sanity/lib/url-for-image";
import type { WORK_HUBS_QUERY_RESULT } from "@/sanity/sanity.types";

type Company = WORK_HUBS_QUERY_RESULT["companies"][number];

interface Props {
  label: string;
  url: Company["url"];
  description: Company["description"];
  logo: Company["logo"];
}

const { label, url, description, logo } = Astro.props;

const logoUrl = logo
  ? urlForImage(logo).width(80).height(80).fit("max").url()
  : null;
---

<header class="space-y-3 md:px-2">
  <div class="flex items-center gap-2.5 text-2xl sm:text-3xl">
    {
      logoUrl && (
        <img
          src={logoUrl}
          alt={`${label} logo`}
          width="40"
          height="40"
          class="size-[1em] shrink-0 object-contain"
          data-reveal
        />
      )
    }
    <h1 class="text-balance text-foreground" data-reveal>
      {label}
    </h1>
  </div>
  {
    description && (
      <p class="lead max-w-[60ch]" data-reveal>
        {description}
      </p>
    )
  }
  {
    url && (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="group/cta inline-flex items-center gap-1 text-sm text-link"
        data-reveal
      >
        Visit website
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-3.5 transition-transform duration-200 ease-out can-hover:group-hover/cta:translate-x-0.5 can-hover:group-hover/cta:-translate-y-0.5"
          aria-hidden="true"
        >
          <path d="M7 7h10v10"></path>
          <path d="M7 17 17 7"></path>
        </svg>
      </a>
    )
  }
</header>
