---
import { sanityClient } from "sanity:client";
import Item from "@/components/Item.astro";
import Layout from "@/layouts/Layout.astro";
import { groupByYear } from "@/sanity/lib/content";
import { APPEARANCES_QUERY } from "@/sanity/lib/queries";
import type { APPEARANCES_QUERY_RESULT } from "@/sanity/sanity.types";

const appearances =
  await sanityClient.fetch<APPEARANCES_QUERY_RESULT>(APPEARANCES_QUERY);
const { byYear: appearancesByYear, years } = groupByYear(appearances);

const description =
  "A collection of my appearances on podcasts, talks, and other media";
---

<Layout title="Appearances — Ryan Furrer" description={description}>
  <div class="space-y-8">
    <header class="space-y-3 md:px-2">
      <h1 class="text-2xl text-balance text-foreground sm:text-3xl" data-reveal>
        Appearances
      </h1>
      <p class="lead max-w-[60ch]" data-reveal>
        {description}
      </p>
    </header>
    <main>
      <div class="space-y-8">
        {
          years.map((year) => (
            <section class="space-y-4">
              <h2 class="small-heading md:px-2" data-reveal>
                {year}
              </h2>
              <ul class="flex flex-col gap-px" role="list">
                {appearancesByYear[year].map((appearance) => (
                  <li>
                    <Item
                      title={appearance.title}
                      href={`/appearances/${appearance.slug?.current}`}
                      publishedAt={appearance.publishedAt}
                    />
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </main>
  </div>
</Layout>
