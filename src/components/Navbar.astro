---
import MobileNav from "@/components/MobileNav";
import ModeToggle from "@/components/ModeToggle";
import NavMenu from "@/components/NavMenu";
import Presence from "@/components/Presence";
import { cn } from "@/lib/utils";

// Top-level desktop items keep the directional traveling-highlight (dir-hover).
const primaryNavItems = [
  { label: "Writing", href: "/writing" },
  { label: "Work", href: "/work" },
  { label: "Appearances", href: "/appearances" },
  { label: "Now", href: "/now" },
];

// The "personal/meta" pages are grouped under one desktop dropdown (NavMenu).
const menuNavItems = [
  { label: "About", href: "/about" },
  { label: "Uses", href: "/uses" },
  { label: "Links", href: "/links" },
];

// Mobile menu leads with Home (the logo is the only desktop home affordance)
// and lists every page flat — grouping is a desktop-only affordance.
const mobileNavItems = [
  { label: "Home", href: "/" },
  ...primaryNavItems,
  ...menuNavItems,
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/"
    ? pathname === "/"
    : pathname === href || pathname.startsWith(`${href}/`);
---

<nav class="md:px-2">
  <div class="flex items-center justify-between">
    <a
      href="/"
      name="go to home page"
      class="block rounded-full"
    >
      <svg
        viewBox="0 0 4167 4167"
        class="size-8"
        role="img"
        aria-label="Ryan Furrer"
        fill="none"
        stroke="var(--link)"
        stroke-width="208.33"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="2083.33" cy="2083.33" r="1875"></circle>
        <path
          d="M3409.16,757.508c365.871,365.872 68.83,1257 -662.913,1988.74c-731.743,731.743 -1622.87,1028.78 -1988.74,662.913c-365.871,-365.872 -68.83,-1257 662.913,-1988.74c731.743,-731.743 1622.87,-1028.78 1988.74,-662.913Z"
        ></path>
        <path
          d="M757.508,757.508c365.872,-365.871 1257,-68.83 1988.74,662.913c731.743,731.743 1028.78,1622.87 662.913,1988.74c-365.872,365.871 -1257,68.83 -1988.74,-662.913c-731.743,-731.743 -1028.78,-1622.87 -662.913,-1988.74Z"
        ></path>
      </svg>
    </a>
    <div class="hidden items-center gap-1 sm:flex">
      <ul class="flex items-center gap-1 text-sm" role="list">
        {
          primaryNavItems.map((item) => (
            <li>
              <a
                href={item.href}
                name={`go to ${item.label.toLowerCase()} page`}
                data-dir-hover="nav"
                aria-current={isActive(item.href) ? "page" : undefined}
                class={cn(
                  "block rounded-md px-3 py-1.5 font-medium transition-colors hover:text-foreground",
                  isActive(item.href)
                    ? "bg-nav-active text-foreground"
                    : "text-foreground-muted",
                )}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <NavMenu
        client:idle
        label="Me"
        items={menuNavItems}
        pathname={pathname}
      />
    </div>
    <div class="flex items-center gap-1 sm:gap-2">
      <div class="flex items-center rounded-md bg-secondary ps-2.5 md:gap-1">
        <Presence client:idle />
        <ModeToggle client:idle />
      </div>
      <div class="sm:hidden">
        <MobileNav client:load navItems={mobileNavItems} pathname={pathname} />
      </div>
    </div>
  </div>
</nav>
