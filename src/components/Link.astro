---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  href: string;
}

const { href, class: className, target, rel, ...restProps } = Astro.props;

let finalRel = rel;
if (target === "_blank" && !rel) {
  finalRel = "noopener noreferrer";
}
---

<!--
  Standalone "read more" CTA: muted ink + trailing arrow that travels on hover,
  and a wipe-in underline under the label (not the arrow) so these editorial
  "continue" links speak the same underline language as the site's inline prose
  links. Arrow uses the decisive ease-ios ease-out (no bounce — a hover carries
  no momentum). Reduced-motion keeps the color + underline crossfade, drops the
  travel.
-->
<a
  href={href}
  class:list={[
    "group/cta inline-flex w-fit items-center gap-1 text-sm font-medium text-foreground-muted no-underline transition-[color,scale] duration-150 ease-out hover:text-foreground focus-visible:text-foreground active:scale-[0.98] motion-reduce:transition-colors",
    className,
  ]}
  target={target}
  rel={finalRel}
  {...restProps}
  ><span
    class="bg-[linear-gradient(currentColor,currentColor)] bg-[length:0%_1.5px] bg-[position:0_100%] bg-no-repeat pb-px transition-[background-size] duration-200 ease-out can-hover:group-hover/cta:bg-[length:100%_1.5px] group-focus-visible/cta:bg-[length:100%_1.5px] motion-reduce:transition-none"
    ><slot /></span
  ><svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="size-4 shrink-0 transition-transform duration-150 ease-ios can-hover:group-hover/cta:translate-x-1 group-focus-visible/cta:translate-x-1 motion-reduce:transition-none"
    aria-hidden="true"
  >
    <path d="M5 12h14"></path>
    <path d="m12 5 7 7-7 7"></path>
  </svg></a
>
