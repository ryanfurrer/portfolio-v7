---
/**
 * ScrollFade — a fixed gradient overlay at the viewport's bottom (and optionally
 * top) edge that dissolves scrolling content into the page background.
 *
 * A single `linear-gradient` of the `--background` token: no backdrop-filter,
 * no JS, no scroll listeners, so it's cheap on every device and adapts to
 * light/dark automatically through the token. The transparent stop is the
 * background color at zero alpha (relative-color syntax) to avoid the grey
 * mid-band you get fading to `transparent` (transparent-black); the keyword
 * fallback on the line above covers browsers without relative color.
 *
 * Props: top/bottom heights ("0" disables that edge).
 */
interface Props {
  top?: string;
  bottom?: string;
}
const { top = "0", bottom = "5rem" } = Astro.props;
const showTop = top !== "0";
const showBottom = bottom !== "0";
---

<div class="pointer-events-none" aria-hidden="true">
  {
    showTop && (
      <div class="sf-bar sf-top fixed inset-x-0 top-0 z-20" style={`height:${top}`} />
    )
  }
  {
    showBottom && (
      <div
        class="sf-bar sf-bottom fixed inset-x-0 bottom-0 z-20"
        style={`height:${bottom}`}
      />
    )
  }
</div>

<style>
  .sf-top {
    background-image: linear-gradient(to bottom, var(--background), transparent);
    background-image: linear-gradient(
      to bottom,
      var(--background),
      rgb(from var(--background) r g b / 0)
    );
  }
  .sf-bottom {
    background-image: linear-gradient(to top, var(--background), transparent);
    background-image: linear-gradient(
      to top,
      var(--background),
      rgb(from var(--background) r g b / 0)
    );
  }
</style>
