# Copy to `.env` (gitignored) and fill in.

# Sanity read token with the "Viewer" role — lets a build read
# unpublished/edited content so drafts render with the real styling. Used by
# local dev (`pnpm dev`) and by Vercel *Preview* deployments only — NEVER set it
# on Production, which must stay published-only. Create one at
# https://www.sanity.io/manage  →  your project  →  API  →  Tokens  →  Add token
# (name it e.g. "draft-preview", role: Viewer). This is a SECRET: never commit it.
SANITY_API_READ_TOKEN=

# Turn draft preview on. When "true" AND a read token is present, the site's
# Sanity client switches to the `drafts` perspective (see astro.config.mjs).
# `pnpm dev` sets this locally; on Vercel, set it (scoped to Preview) alongside
# the token. Previews are a build-time draft snapshot — draft edits only appear
# after a new deployment. Leave unset/false for Production.
SANITY_PREVIEW_DRAFTS=
