---
/**
 * Callout — a labelled, colour-coded aside for posts and anywhere on the site.
 *
 * Props-driven so it works standalone (`<Callout variant="tip">…</Callout>`);
 * a thin Portable Text wrapper (CalloutBlock.astro) will feed it Sanity data.
 * Body is a slot so it inherits the site's link/emphasis styling.
 *
 * Icons are inline lucide paths (crisp + themeable, aria-hidden). Danger uses
 * rose rather than pure red so it never competes with the vermilion accent that
 * the site reserves for interactivity.
 */
type Variant = "info" | "tip" | "important" | "warning" | "caution";

interface Props {
  variant?: Variant;
  /** Override the default label for this variant. */
  title?: string;
}

const { variant = "info", title }: Props = Astro.props;

const VARIANTS: Record<
  Variant,
  { label: string; surface: string; accent: string; icon: string }
> = {
  info: {
    label: "Note",
    surface:
      "bg-sky-50 border-sky-300/80 dark:bg-sky-950/40 dark:border-sky-900/60",
    accent: "text-sky-700 dark:text-sky-300",
    // lucide: info
    icon: '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
  },
  tip: {
    label: "Tip",
    surface:
      "bg-emerald-50 border-emerald-300/80 dark:bg-emerald-950/40 dark:border-emerald-900/60",
    accent: "text-emerald-700 dark:text-emerald-300",
    // lucide: lightbulb
    icon: '<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>',
  },
  important: {
    label: "Important",
    surface:
      "bg-violet-50 border-violet-300/80 dark:bg-violet-950/40 dark:border-violet-900/60",
    accent: "text-violet-700 dark:text-violet-300",
    // lucide: star
    icon: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
  },
  warning: {
    label: "Warning",
    surface:
      "bg-amber-50 border-amber-300/80 dark:bg-amber-950/40 dark:border-amber-900/60",
    accent: "text-amber-700 dark:text-amber-300",
    // lucide: triangle-alert
    icon: '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>',
  },
  caution: {
    label: "Caution",
    surface:
      "bg-rose-50 border-rose-300/80 dark:bg-rose-950/40 dark:border-rose-900/60",
    accent: "text-rose-700 dark:text-rose-300",
    // lucide: octagon-alert
    icon: '<path d="M12 16h.01"/><path d="M12 8v4"/><path d="M15.312 2a2 2 0 0 1 1.414.586l4.688 4.688A2 2 0 0 1 22 8.688v6.624a2 2 0 0 1-.586 1.414l-4.688 4.688a2 2 0 0 1-1.414.586H8.688a2 2 0 0 1-1.414-.586l-4.688-4.688A2 2 0 0 1 2 15.312V8.688a2 2 0 0 1 .586-1.414l4.688-4.688A2 2 0 0 1 8.688 2z"/>',
  },
};

const { label, surface, accent, icon } = VARIANTS[variant];
const heading = title ?? label;
---

<div
  role="note"
  class:list={[
    "my-6 rounded-lg border p-4 shadow-sm dark:shadow-none",
    surface,
  ]}
>
  <div class:list={["flex items-center gap-2", accent]}>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="shrink-0"
      aria-hidden="true"
      set:html={icon}
    />
    <span class="text-sm font-semibold tracking-tight">{heading}</span>
  </div>
  <div
    class="[&_a]:decoration-skip-ink mt-1.5 text-sm/6 text-pretty text-foreground [&_a]:font-medium [&_a]:underline [&_p]:m-0 [&_p+p]:mt-2"
  >
    <slot />
  </div>
</div>
