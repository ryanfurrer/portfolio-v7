---
import BlueskyIcon from "@/assets/icons/bluesky.svg";
import GithubIcon from "@/assets/icons/github.svg";
import LinkedinIcon from "@/assets/icons/linkedin2.svg";
import TwitchIcon from "@/assets/icons/twitch.svg";
import XIcon from "@/assets/icons/x.svg";
import YoutubeIcon from "@/assets/icons/youtube.svg";
import profilePicture from "@/assets/profile-picture.webp";
import Button from "@/components/ui/Button.astro";
import LinksCard from "@/components/ui/LinksCard.astro";
import Layout from "@/layouts/Layout.astro";
import { urlForImage } from "@/sanity/lib/url-for-image";
import { LINKS_LATEST_QUERY } from "@/sanity/lib/queries";
import type { LINKS_LATEST_QUERY_RESULT } from "@/sanity/sanity.types";
import { sanityClient } from "sanity:client";
import { formatFollowerCount } from "@/utils/links";

type LatestLinkItem = NonNullable<LINKS_LATEST_QUERY_RESULT["post"]>;

const {
  post: latestPost,
  project: latestProject,
  appearance: latestAppearance,
} = await sanityClient.fetch<LINKS_LATEST_QUERY_RESULT>(LINKS_LATEST_QUERY);

const getOgImageUrl = (item: LatestLinkItem | null) =>
  item?.ogImage ? urlForImage(item.ogImage).url() : undefined;

const latestContentItems = [
  {
    type: "writing",
    path: "writing",
    item: latestPost,
    ogImageUrl: getOgImageUrl(latestPost),
  },
  {
    type: "work",
    path: "work",
    item: latestProject,
    ogImageUrl: getOgImageUrl(latestProject),
  },
  {
    type: "appearance",
    path: "appearances",
    item: latestAppearance,
    ogImageUrl: getOgImageUrl(latestAppearance),
  },
].filter(
  (content): content is typeof content & { item: LatestLinkItem } =>
    content.item !== null,
);

const description = "A collection of links to my work, writing, and more";
const shortBio = `Frontend Engineer
Designer
Creator`;

const socialLinks = [
  {
    label: "Twitter/X",
    href: "https://x.com/ryandotfurrer",
    followerCount: 970,
    icon: XIcon,
    iconFill: "fill-white",
    iconBackground: "bg-zinc-950",
    actionLabel: "Follow",
  },
  {
    label: "Bluesky",
    href: "https://bsky.app/profile/ryandotfurrer.bsky.social",
    followerCount: 764,
    icon: BlueskyIcon,
    iconFill: "fill-white",
    iconBackground: "bg-sky-500",
    actionLabel: "Follow",
  },
  {
    label: "Twitch",
    href: "https://www.twitch.tv/ryandotfurrer",
    followerCount: 178,
    icon: TwitchIcon,
    iconFill: "fill-white",
    iconBackground: "bg-violet-600",
    actionLabel: "Follow",
  },
  {
    label: "YouTube",
    href: "https://www.youtube.com/@ryandotfurrer",
    followerCount: 46,
    icon: YoutubeIcon,
    iconFill: "fill-white",
    iconBackground: "bg-rose-600",
    actionLabel: "Subscribe",
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/ryanfurrer/",
    followerCount: 1920,
    icon: LinkedinIcon,
    iconFill: "fill-white stroke-none",
    iconBackground: "bg-blue-600",
    actionLabel: "Follow",
  },
  {
    label: "GitHub",
    href: "https://github.com/ryandotfurrer",
    followerCount: 59,
    icon: GithubIcon,
    iconFill: "fill-white",
    iconBackground: "bg-zinc-950",
    actionLabel: "Follow",
  },
];
---

<Layout
  title="Links — Ryan Furrer"
  description={description}
  noNavbar
  noFooter
  maxWidth="sm"
>
  <div class="space-y-16">
    <header class="space-y-8">
      <div class="flex items-center gap-8" data-reveal>
        <div
          class="size-full max-w-36 overflow-hidden rounded-full ring-1 ring-black/10 dark:ring-white/10"
        >
          <img src={profilePicture.src} alt="Ryan Furrer" class="" />
        </div>
        <div class="space-y-2">
          <h1 class="text-3xl font-semibold tracking-tight text-foreground">
            Ryan Furrer
          </h1>
          <p class="text-lg/5 font-medium text-pretty whitespace-pre-line">
            {shortBio}
          </p>
        </div>
      </div>
      <div data-reveal>
        <Button
          href="/"
          class="dark:inset-ring dark:inset-ring-white/10 dark:bg-surface dark:text-foreground dark:hover:bg-surface-hover"
          >Go to ryanfurrer.com</Button
        >
      </div>
    </header>
    <main class="space-y-16">
      <section class="space-y-4">
        <h2 data-reveal>Connect with me</h2>
        <div class="grid grid-cols-2 gap-4">
          {
            socialLinks.map((link) => {
              const IconComponent = link.icon;
              return (
                <LinksCard
                  href={link.href}
                  class="squircle rounded-3xl bg-surface p-4 hover:bg-surface-hover"
                >
                  <div class="flex items-start justify-between gap-2">
                    <IconComponent
                      class:list={[
                        "squircle size-9 shrink-0 rounded-xl p-2",
                        link.iconFill,
                        link.iconBackground,
                      ]}
                    />
                    <span class="pointer-events-none inline-flex items-center justify-center rounded-md px-2 py-1 text-xs font-medium text-foreground-subtle">
                      {link.actionLabel}
                    </span>
                  </div>
                  <div class="mt-3 space-y-0.5">
                    <h3 class="small-heading leading-none">{link.label}</h3>
                    <p class="text-4xl font-bold leading-none text-foreground">
                      {formatFollowerCount(link.followerCount)}
                      <span class="mt-1 block text-sm font-normal text-foreground-subtle">
                        {link.actionLabel === "Subscribe"
                          ? "subscribers"
                          : "followers"}
                      </span>
                    </p>
                  </div>
                </LinksCard>
              );
            })
          }
        </div>
      </section>
      {
        latestContentItems.length > 0 && (
          <section class="space-y-4">
            <h2 data-reveal>My Latest Work</h2>
            <div class="grid grid-cols-1 gap-4">
              {latestContentItems.map((content) => (
                <LinksCard
                  href={`/${content.path}/${content.item.slug?.current}`}
                >
                  <header class="flex items-center pt-1 pb-2">
                    <p class="small-heading leading-none">{content.type}</p>
                    <h3 class="sr-only">{content.item.title}</h3>
                  </header>
                  {content.ogImageUrl && (
                    <div class="overflow-hidden rounded-md ring-1 ring-black/10 dark:ring-white/10">
                      <img src={content.ogImageUrl} alt={content.item.title} />
                    </div>
                  )}
                </LinksCard>
              ))}
            </div>
          </section>
        )
      }
      <div data-reveal>
        <Button
          href="/"
          class="dark:inset-ring dark:inset-ring-white/10 dark:bg-surface dark:text-foreground dark:hover:bg-surface-hover"
          >Go to ryanfurrer.com</Button
        >
      </div>
    </main>
  </div>
</Layout>
