---
import Signature from "@/components/Signature.astro";
import Layout from "@/layouts/Layout.astro";

const description = "Learn more about me";
---

<Layout title="About — Ryan Furrer" description={description}>
  <div class="space-y-8 md:px-2">
    <header class="space-y-2">
      <h1 class="text-2xl text-balance text-foreground sm:text-3xl" data-reveal>
        About
      </h1>
      <p class="max-w-[60ch] text-pretty text-foreground-muted" data-reveal>
        {description}
      </p>
    </header>
    <main class="space-y-4" data-reveal>
      <p>
        I'm Ryan Furrer, a Frontend Engineer who cares about how things look,
        how they feel, accessibility, and more. I thrive on tight-knit,
        fast-moving teams where we ship often, iterate quickly, and can actually
        see the impact of our work.
      </p>
      <p>
        I believe great products come from sweating the details and caring about
        the craft. I'm always looking for new challenges and opportunities to
        learn and grow.
      </p>
      <p>
        When I'm not working, you'll probably find me tinkering with side
        projects, writing about what I'm learning, or exploring new tools and
        projects.
      </p>
      <p>
        Or, if I need some downtime, I'll fire up a game or catch up on whatever
        shows or anime I've been putting off. <a href="/now"
          >Check out what I'm currently up to!</a
        >
      </p>
      <Signature />
    </main>
  </div>
</Layout>
